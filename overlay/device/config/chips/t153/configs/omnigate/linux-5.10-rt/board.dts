&soc {
	e907_rproc: e907_rproc@1a00000 {
		mboxes = <&msgbox 0>, <&msgbox 2>;
		mbox-names = "arm-kick", "arm-standby";
		memory-region = <&rv_vdev0buffer>, <&rv_vdev0vring0>, <&rv_vdev0vring1>, <&e907_dram_reserved>;
		fw-region = <&e907_mem_fw>;
		fw-partitions = "riscv0", "riscv0-r";
		fw-partition-sectors = <2048>;
		memory-mappings =
			/* < DA      len        PA >	*/
			/* SRAM A2 */
			< 0x40000    0x2BFFF    0x40000 >,
			/* SHARED SRAM */
			< 0x1000000  0x7ffff    0x1000000 >,
			/* DRAM SPACE1 */
			< 0x40000000 0x3f000000 0x40000000>,
			/* DRAM SPACE2 */
			< 0x80000000 0x3f000000 0x80000000>,
			/* DRAM SPACE3 */
			< 0xC0000000 0x3f000000 0xC0000000>;
		standby-ctrl-en = <0x1>;
		standby-record-reg = <0x07090114>;
		share-irq = "e907";
		//auto-boot;
		status = "okay";
		rproc_wdt: rproc_wdt@0 {
			timeout_ms = <6000>;
			try_times = <3>;
			reset_type = <0x2>;
			status="okay";
		};
	};

	gpio-keys {
		compatible = "gpio-keys";
		status = "okay";

		power {
			label = "Power Button";
			linux,code = <KEY_POWER>;
			debounce-interval = <20>;
			//gpios = <&rtc_pio PW 1 GPIO_ACTIVE_HIGH>;
		};

		volume-up {
			label = "Volume Up";
			linux,code = <KEY_VOLUMEUP>;
			debounce-interval = <20>;
			//gpios = <&rtc_pio PW 2 GPIO_ACTIVE_HIGH>;
		};

		volume-down {
			label = "Volume Down";
			linux,code = <KEY_VOLUMEDOWN>;
			debounce-interval = <20>;
			//gpios = <&rtc_pio PW 3 GPIO_ACTIVE_HIGH>;
		};
	};

	auto_print@54321 {
		reg = <0x0 0x54321 0x0 0x0>;
		device_type = "auto_print";
		status = "okay";
	};

	mailbox_test: mailbox_test@0 {
		compatible = "core0-mailbox-test";
		mboxes = <&msgbox_core0 7>;
		mbox-names = "tx|rx0";
		status = "okay";
	};
};

&spi0 {
	pinctrl-0 = <&spi0_pins_default &spi0_pins_cs &spi0_pins_clk>;
	pinctrl-1 = <&spi0_pins_sleep>;
	pinctrl-names = "default", "sleep";
	sunxi,spi-bus-mode = <SUNXI_SPI_BUS_NAND>;
	sunxi,spi-cs-mode = <SUNXI_SPI_CS_SOFT>;
	status = "okay";

	spi-nand@0 {
			compatible = "spi-nand";
			spi-max-frequency=<100000000>;
			reg = <0x0>;
			spi-rx-bus-width=<0x04>;
			spi-tx-bus-width=<0x04>;
			status="okay";
	};
};

&sdc2 {
	non-removable;
	bus-width = <8>;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	no-sdio;
	no-sd;
	ctl-spec-caps = <0x328>;
	cap-mmc-highspeed;
	sunxi-power-save-mode;
	sunxi-dis-signal-vol-sw;
	mmc-bootpart-noacc;
	/*cap-hsq;*/
	cqe-on;
	ctl-cmdq-md = <0x2>;
	/* b2c-ecc-on; */
	/* cqe-ecc-on; */
	max-frequency = <150000000>;
	/*vmmc-supply = <&reg_cldo3>;*/
	/*emmc io vol 3.3v*/
	/*vqmmc-supply = <&reg_aldo1>;*/
	/*emmc io vol 1.8v*/
	/*vqmmc-supply = <&reg_cldo1>;*/
	status = "disabled";
};

&sdc0 {
	bus-width = <4>;
	cd-gpios = <&pio PF 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	/*non-removable;*/
	/*broken-cd;*/
	/*cd-inverted*/
	/*data3-detect;*/
	/*card-pwr-gpios = <&pio PH 14 1 1 2 0xffffffff>;*/
	cd-used-24M;
	cd-set-debounce = <0x1>;
	cap-sd-highspeed;
	sd-uhs-sdr50;
	sd-uhs-ddr50;
	sd-uhs-sdr104;
	no-sdio;
	no-mmc;
	/* b2c-ecc-on; */
	sunxi-power-save-mode;
	/*sunxi-dis-signal-vol-sw;*/
	sunxi-signal-vol-sw-without-pmu;
	max-frequency = <150000000>;
	ctl-spec-caps = <0x428>;
	/*vmmc-supply = <&reg_cldo3>;*/
	/*vqmmc33sw-supply = <&reg_cldo3>;*/
	/*vdmmc33sw-supply = <&reg_cldo3>;*/
	/*vqmmc18sw-supply = <&reg_aldo4>;*/
	/*vdmmc18sw-supply = <&reg_aldo4>;*/
	status = "okay";
};

&sdc1 {
	bus-width = <4>;
	no-mmc;
	no-sd;
	cap-sd-highspeed;
	/*sd-uhs-sdr12*/
	sd-uhs-sdr25;
	sd-uhs-sdr50;
	sd-uhs-ddr50;
	sd-uhs-sdr104;
	/*sunxi-power-save-mode;*/
	sunxi-dis-signal-vol-sw;
	cap-sdio-irq;
	keep-power-in-suspend;
	ignore-pm-notify;
	max-frequency = <150000000>;
	ctl-spec-caps = <0x428>;
	status = "okay";
};

&spi3 {
	pinctrl-0 = <&spi3_pins_default &spi3_pins_cs>;
	pinctrl-1 = <&spi3_pins_sleep>;
	pinctrl-names = "default", "sleep";
	sunxi,spi-bus-mode = <SUNXI_SPI_BUS_MASTER>;
	sunxi,spi-cs-mode = <SUNXI_SPI_CS_AUTO>;
	status = "disabled";
};

/*
 *usb_port_type: usb mode. 0-device, 1-host, 2-otg.
 *usb_detect_type: usb hotplug detect mode. 0-none, 1-vbus/id detect, 2-id/dpdm detect.
 *usb_detect_mode: 0-thread scan, 1-id gpio interrupt.
 *usb_id_gpio: gpio for id detect.
 *usb_det_vbus_gpio: gpio for id detect. gpio or "axp_ctrl";
 *usb_wakeup_suspend:0-SUPER_STANDBY, 1-USB_STANDBY.
 */
&usbc0 {
	device_type = "usbc0";
	usb_port_type = <0x2>;
	usb_detect_type = <0x1>;
	usb_detect_mode = <0>;
	usb_id_gpio = <&pio PB 11 GPIO_ACTIVE_HIGH>;
	enable-active-high;
	usb_det_vbus_gpio = <&pio PB 12 GPIO_ACTIVE_HIGH>;
	usb_wakeup_suspend = <0>;
	usb_serial_unique = <0>;
	usb_serial_number = "20080411";
	rndis_wceis = <1>;
	status = "okay";
};

&u2phy {
	status = "okay";
};

&udc {
	status = "okay";
};

&ehci0 {
	drvvbus-supply = <&reg_usb0_vbus>;
	status = "okay";
};

&ohci0 {
	drvvbus-supply = <&reg_usb0_vbus>;
	status = "okay";
};

&usbc1 {
	device_type = "usbc1";
	usb_regulator_io = "nocare";
	status = "okay";
};

&ehci1 {
	drvvbus-supply = <&reg_usb1_vbus>;
	status = "okay";
};

&ohci1 {
	drvvbus-supply = <&reg_usb1_vbus>;
	status = "okay";
};

&twi2 {
	clock-frequency = <400000>;
	pinctrl-0 = <&twi2_pins_default>;
	pinctrl-1 = <&twi2_pins_sleep>;
	pinctrl-names = "default", "sleep";
	/* For stability and backwards compatibility, we recommend setting 'twi_drv_used' to 1 */
	twi_drv_used = <1>;
	/* twi-supply = <&reg_cldo3>; */
	status = "disabled";

	pcf8563: rtc@51 {
		compatible = "nxp,pcf8563";
		reg = <0x51>;
	};
};

&twi4 {
	clock-frequency = <400000>;
	pinctrl-0 = <&twi4_pins_default>;
	pinctrl-1 = <&twi4_pins_sleep>;
	pinctrl-names = "default", "sleep";
	/* For stability and backwards compatibility, we recommend setting 'twi_drv_used' to 1 */
	twi_drv_used = <1>;
	no_suspend = <1>;
	/* twi-supply = <&reg_cldo3>; */
	status = "disabled";
};

&pwmcs0_0 {
	pinctrl-names = "active", "sleep";
	pinctrl-0 = <&pwmcs0_0_pins_active>;
	pinctrl-1 = <&pwmcs0_0_pins_sleep>;
	status = "okay";
};

&pwmcs0_4 {
	pinctrl-names = "active", "sleep";
	pinctrl-0 = <&pwmcs0_4_pins_active>;
	pinctrl-1 = <&pwmcs0_4_pins_sleep>;
	status = "okay";
};

&cpu0 {
	cpu-supply = <&reg_vdd_cpu>;
};

&gpadc0 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&gpadc0_pins_default>;
	pinctrl-1 = <&gpadc0_pins_sleep>;
	channel_num = <10>;
	channel_select = <3>;
	channel_data_select = <0>;
	channel_compare_select = <0>;
	channel_cld_select = <3>;
	channel_chd_select = <0>;
	channel0_compare_lowdata = <1700000>;
	channel0_compare_higdata = <1200000>;
	channel1_compare_lowdata = <460000>;
	channel1_compare_higdata = <1200000>;
	status = "disabled";
};

&gpadc1 {
	channel_num = <10>;
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&gpadc1_pins_default>;
	pinctrl-1 = <&gpadc1_pins_sleep>;
	channel_select = <0x2>;
	channel_data_select = <0>;
	channel_compare_select = <0x2>;
	channel_cld_select = <0x2>;
	channel_chd_select = <0>;
	channel0_compare_lowdata = <1700000>;
	channel0_compare_higdata = <1200000>;
	channel1_compare_lowdata = <900000>;
	channel1_compare_higdata = <0>;
	status = "disabled";
	keyadc1 {
		key_cnt = <5>;
		key0_vol = <210>;
		key0_val = <115>;
		key1_vol = <410>;
		key1_val = <114>;
		key2_vol = <590>;
		key2_val = <139>;
		key3_vol = <750>;
		key3_val = <28>;
		key4_vol = <880>;
		key4_val = <102>;
	};
};

&gpadc2 {
	channel_num = <4>;
	only_used_for_gpadc;
	channel_select = <3>;
	channel_data_select = <0>;
	channel_compare_select = <0>;
	channel_cld_select = <3>;
	channel_chd_select = <0>;
	channel0_compare_lowdata = <1700000>;
	channel0_compare_higdata = <1200000>;
	channel1_compare_lowdata = <460000>;
	channel1_compare_higdata = <1200000>;
	status = "disabled";
};

&gpadc3 {
	channel_num = <2>;
	channel_select = <3>;
	channel_data_select = <0>;
	channel_compare_select = <0>;
	channel_cld_select = <3>;
	channel_chd_select = <0>;
	channel0_compare_lowdata = <1700000>;
	channel0_compare_higdata = <1200000>;
	channel1_compare_lowdata = <460000>;
	channel1_compare_higdata = <1200000>;
	status = "disabled";
};

&rfkill {
	compatible = "allwinner,sunxi-rfkill";
	chip_en;
	power_en;
	pinctrl-0;
	pinctrl-names;
	status = "okay";

	/* wlan session */
	wlan {
		compatible    = "allwinner,sunxi-wlan";
		wlan_busnum   = <0x1>;
		wlan_regon    = <&pio PG 13 GPIO_ACTIVE_HIGH>;
		wlan_hostwake = <&pio PG 11 GPIO_ACTIVE_HIGH>;
		wakeup-source;
		regulator-boot-on;
		regulator-always-on;
	};

	/* bt session */
	bt {
		compatible    = "allwinner,sunxi-bt";
		bt_rst_n      = <&pio PG 12 GPIO_ACTIVE_LOW>;
		status        = "okay";
	};

};

&btlpm {
	compatible  = "allwinner,sunxi-btlpm";
	uart_index  = <0x1>;
	bt_wake     = <&pio PG 14 GPIO_ACTIVE_HIGH>;
	bt_hostwake = <&pio PG 15 GPIO_ACTIVE_HIGH>;
	/* wakeup-source; */
	status      = "okay";
};

&addr_mgt {
	compatible = "allwinner,sunxi-addr_mgt";
	type_addr_wifi = <0x0>;
	type_addr_bt   = <0x0>;
	type_addr_eth  = <0x0>;
	status = "okay";
};

&irrx0 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irrx0_pins_default>;
	pinctrl-1 = <&irrx0_pins_sleep>;
	status = "okay";
};

&irrx1 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irrx1_pins_default>;
	pinctrl-1 = <&irrx1_pins_sleep>;
	status = "disabled";
};

&irrx2 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irrx2_pins_default>;
	pinctrl-1 = <&irrx2_pins_sleep>;
	status = "disabled";
};

&irrx3 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irrx3_pins_default>;
	pinctrl-1 = <&irrx3_pins_sleep>;
	status = "disabled";
};

&irtx0 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&irtx0_pins_default>;
	pinctrl-1 = <&irtx0_pins_sleep>;
	status = "okay";
};

&ledc  {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&ledc_pins_default>;
	pinctrl-1 = <&ledc_pins_sleep>;
	led_count = <32>;
	output_mode = "GRB";
	reset_ns = <84>;
	t1h_ns = <800>;
	t1l_ns = <320>;
	t0h_ns = <300>;
	t0l_ns = <800>;
	wait_time0_ns = <84>;
	wait_time1_ns = <84>;
	wait_data_time_ns = <600000>;
	status = "disabled";
};

/* audio dirver module -> audio codec */
&codec {
	tx-hub-en;

	dac-vol		= <63>;		/* default value:63 range:0->63 */
	dacl-vol	= <160>;	/* default value:160 range:0->255 */
	lineout-gain	= <31>;		/* default value:31 range:0->31 */

	pa-pin-max	= <1>;
	pa-pin-0	= <&pio PB 14 GPIO_ACTIVE_HIGH>;
	pa-pin-level-0	= <1>;
	pa-pin-msleep-0	= <0>;

	status = "okay";
};

&codec_plat {
	status = "okay";
};

&codec_mach {
	status = "okay";
	soundcard-mach,cpu {
		sound-dai = <&codec_plat>;
	};
	soundcard-mach,codec {
		sound-dai = <&codec>;
	};
};

/* audio dirver module -> owa */
&owa_plat {
	/* pinctrl-used; */
	/* pinctrl-names	= "default","sleep"; */
	/* pinctrl-0	= <&owa_pins_a>; */
	/* pinctrl-1	= <&owa_pins_b>; */
	tx-hub-en;

	status		= "disabled";
};

&owa_mach {
	status		= "disabled";
	soundcard-mach,cpu {
		sound-dai = <&owa_plat>;
	};
	soundcard-mach,codec {
	};
};

/* audio dirver module -> DMIC */
&dmic_plat {
	rx-chmap	= <0x76543210>;
	data-vol	= <0xB0>;
	rxdelaytime	= <0>;
	pinctrl-used;
	pinctrl-names	= "default","sleep";
	pinctrl-0	= <&dmic_pins_a>;
	pinctrl-1	= <&dmic_pins_b>;
	rx-sync-en;
	status		= "disabled";
};

&dmic_mach {
	status		= "disabled";
	soundcard-mach,cpu {
		sound-dai = <&dmic_plat>;
	};
	soundcard-mach,codec {
	};
};

/* audio dirver module -> I2S/PCM */
&i2s0_plat {
	tdm-num		= <0>;
	tx-pin		= <0>;
	rx-pin		= <0>;
	/* pinctrl-used; */
	/* pinctrl-names	= "default","sleep"; */
	/* pinctrl-0	= <&i2s0_pins_a &i2s0_pins_c>; */
	/* pinctrl-1	= <&i2s0_pins_b &i2s0_pins_d>; */
	tx-hub-en;
	rx-sync-en;
	status		= "disabled";
};

&i2s0_mach {
	soundcard-mach,format		= "i2s";
	soundcard-mach,frame-master	= <&i2s0_cpu>;
	soundcard-mach,bitclock-master	= <&i2s0_cpu>;
	/* soundcard-mach,frame-inversion; */
	/* soundcard-mach,bitclock-inversion; */
	soundcard-mach,slot-num		= <2>;
	soundcard-mach,slot-width	= <32>;
	soundcard-mach,capture-only;
	status		= "disabled";
	i2s0_cpu: soundcard-mach,cpu {
		sound-dai = <&i2s0_plat>;
		/* note: pll freq = 24.576M or 22.5792M * pll-fs */
		soundcard-mach,pll-fs	= <1>;
		/* note:
		 * mclk freq = mclk-fs * 12.288M or 11.2896M	(when mclk-fp ture)
		 * mclk freq = mclk-fs * pcm rate		(when mclk-fp false)
		 */
		soundcard-mach,mclk-fs	= <1>;
		soundcard-mach,mclk-fp;
	};
	i2s0_codec: soundcard-mach,codec {
		soundcard-mach,pll-fs   = <1>;
	};
};

&i2s1_plat {
	tdm-num		= <1>;
	tx-pin		= <0>;
	rx-pin		= <0>;
	/* pinctrl-used; */
	/* pinctrl-names= "default","sleep"; */
	/* pinctrl-0	= <&i2s1_pins_a &i2s1_pins_b &i2s1_pins_c &i2s1_pins_d>; */
	/* pinctrl-1	= <&i2s1_pins_e>; */
	tx-hub-en;
	rx-sync-en;
	status		= "disabled";
};

&i2s1_mach {
	soundcard-mach,format		= "dsp_a";
	soundcard-mach,frame-master	= <&i2s1_cpu>;
	soundcard-mach,bitclock-master	= <&i2s1_cpu>;
	/* soundcard-mach,frame-inversion; */
	soundcard-mach,bitclock-inversion;
	soundcard-mach,slot-num		= <2>;
	soundcard-mach,slot-width	= <16>;
	status		= "disabled";
	i2s1_cpu: soundcard-mach,cpu {
		sound-dai = <&i2s1_plat>;
		soundcard-mach,pll-fs	= <1>;
		soundcard-mach,mclk-fs	= <0>;
	};
	i2s1_codec: soundcard-mach,codec {
	};
};

&i2s2_plat {
	tdm-num		= <2>;
	tx-pin		= <0 1 2 3>;

	rx-pin		= <0>;
	/* pinctrl-used; */
	/* pinctrl-names= "default","sleep"; */
	/* pinctrl-0	= <&i2s2_pins_a>; */
	/* pinctrl-1	= <&i2s2_pins_b>; */
	tx-hub-en;
	rx-sync-en;
	/* edp not need dai-type */
	status		= "disabled";
};

&i2s2_mach {
	soundcard-mach,format		= "i2s";
	soundcard-mach,frame-master	= <&i2s2_cpu>;
	soundcard-mach,bitclock-master	= <&i2s2_cpu>;
	/* soundcard-mach,frame-inversion; */
	/* soundcard-mach,bitclock-inversion; */
	soundcard-mach,slot-num		= <2>;
	soundcard-mach,slot-width	= <32>;
	status		= "disabled";
	i2s2_cpu: soundcard-mach,cpu {
		sound-dai = <&i2s2_plat>;
		soundcard-mach,pll-fs	= <1>;
		/* edp mclk: 512fs */
		soundcard-mach,mclk-fs	= <0>;
	};
	i2s2_codec: soundcard-mach,codec {

	};
};

&spi2 {
	pinctrl-0 = <&spi2_pins_default &spi2_pins_cs>;
	pinctrl-1 = <&spi2_pins_sleep>;
	pinctrl-names = "default", "sleep";
	sunxi,spi-bus-mode = <SUNXI_SPI_BUS_MASTER>;
	sunxi,spi-cs-mode = <SUNXI_SPI_CS_AUTO>;
	// ready-gpio = <&pio PC 15 GPIO_ACTIVE_LOW>;
	status = "disabled";

	spidev@0 {
		compatible = "rohm,dh2228fv";
		reg = <0x0>;
		spi-max-frequency = <10000000>;
		spi-rx-bus-width = <1>;
		spi-tx-bus-width = <1>;
		status = "disabled";
	};

	aw_spi_lbc@1 {
		compatible = "allwinner, aw-spi-lbc";
		reg = <0x01>;
		spi-lsb-first;
		spi-cs-high;
		spi-cpha;
		spi-max-frequency = <10000000>;
		spi-rx-bus-width = <1>;
		spi-tx-bus-width = <1>;
		status = "disabled";
	};
};

&gmac0_phy0 {
	compatible = "ethernet-phy-id001c.c916";
	reset-gpios = <&pio PE 0 GPIO_ACTIVE_HIGH>;
	/* For RTL8211F: PHY datasheet rst time */
	reset-assert-us = <10000>;
	reset-deassert-us = <30000>;
};

&gmac0 {
	phy-mode = "rgmii";
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&gmac0_pins_default>;
	pinctrl-1 = <&gmac0_pins_sleep>;
	phy-handle = <&gmac0_phy0>;
	aw,soc-phy-clk-en;
	tx-delay = <9>;
	rx-delay = <6>;
	// dwmac-supply = <&reg_dcdc1>;
	// phy-supply = <&reg_dcdc1>;
	status = "disabled";
};

&gmac1_phy0 {
	compatible = "ethernet-phy-id001c.c916";
	reset-gpios = <&pio PE 9 GPIO_ACTIVE_HIGH>;
	/* For RTL8211F: PHY datasheet rst time */
	reset-assert-us = <10000>;
	reset-deassert-us = <30000>;
};

&gmac1 {
	phy-mode = "rgmii";
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&gmac1_pins_default>;
	pinctrl-1 = <&gmac1_pins_sleep>;
	phy-handle = <&gmac1_phy0>;
	aw,soc-phy-clk-en;
	tx-delay = <9>;
	rx-delay = <5>;
	// dwmac-supply = <&reg_dcdc1>;
	// phy-supply = <&reg_dcdc1>;
	status = "disabled";
};

&dma {
	reset-control;
};

&dma1 {
       status="disabled";
};

&rtp {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&rtp_pins_default>;
	pinctrl-1 = <&rtp_pins_sleep>;
	allwinner,tp-sensitive-adjust = <0xa>;
	allwinner,filter-type = <0x3>;
	status = "disabled";
};


&csi_mclk2_pins_a {
	pins = "PA6";
	function = "ncsi";
	drive-strength = <20>;
};

&csi_mclk2_pins_b {
	pins = "PA6";
	function = "gpio_in";
};

&ncsi_8bit_pins_a {
	pins = 	"PA7", "PA4", "PA5",
		"PA8", "PA9", "PA10", "PA11",
		"PA12", "PA13", "PA14", "PA15";
	function = "ncsi";
	drive-strength = <10>;
};

&ncsi_8bit_pins_b {
	pins = 	"PA7", "PA4", "PA5",
		"PA8", "PA9", "PA10", "PA11",
		"PA12", "PA13", "PA14", "PA15";
	function = "gpio_in";
};

&vind0 {
      csi_top = <300000000>;
      csi_isp = <300000000>;
      vind_mclkpin-supply = <>; /* vcc-pe */
      vind_mclkpin_vol = <1800000>;
      vind_mcsipin-supply = <>;  /* vcc-mcsi */
      vind_mcsipin_vol = <1800000>;
      vind_mipipin-supply = <>;  /* vcc-pk */
      vind_mipipin_vol = <1800000>;
      status = "disabled";

      csi2: csi@5822000 {
              pinctrl-names = "default","sleep";
              pinctrl-0 = <&ncsi_8bit_pins_a>;
              pinctrl-1 = <&ncsi_8bit_pins_b>;
              status = "okay";
      };

      tdm0:tdm@5908000 {
              work_mode = <0>;
              status = "disabled";
      };

      isp00:isp@5900000 {
              work_mode = <0>;
              status = "okay";
      };

      isp01:isp@5902000 {
              status = "disabled";
      };

      isp10:isp@2 {
              status = "okay";
      };

      isp20:isp@3 {
              status = "okay";
      };

      scaler00:scaler@5910000 {
              work_mode = <0>;
              status = "okay";
      };

      scaler01:scaler@590fffc {
              status = "disabled";
      };

      scaler10:scaler@5910400 {
              work_mode = <0>;
              status = "okay";
      };

      scaler11:scaler@59103fc {
              status = "disabled";
      };

      scaler20:scaler@8 {
              work_mode = <0>;
              status = "disabled";
      };

      actuator0: actuator@2108180 {
              device_type = "actuator0";
              actuator0_name = "cn3927_act";
              actuator0_slave = <0x18>;
              actuator0_af_pwdn = <>;
              actuator0_afvdd = "afvcc-csi";
              actuator0_afvdd_vol = <2800000>;
              status = "disabled";
      };

      flash0: flash@2108190 {
              device_type = "flash0";
              flash0_type = <2>;
              flash0_en = <>;
              flash0_mode = <>;
              flash0_flvdd = "";
              flash0_flvdd_vol = <>;
              device_id = <0>;
              status = "disabled";
      };

      sensor0:sensor@5812000 {
              device_type = "sensor0";
              sensor0_mname = "tp2815_mipi";
              sensor0_twi_cci_id = <5>;
              sensor0_twi_addr = <0x88>;
              sensor0_mclk_id = <2>;
              sensor0_pos = "rear";
              sensor0_isp_used = <0>;
              sensor0_fmt = <0>;
              sensor0_stby_mode = <0>;
              sensor0_vflip = <0>;
              sensor0_hflip = <0>;
              sensor0_cameravdd-supply = <>;
              sensor0_cameravdd_vol = <>;
              sensor0_iovdd-supply = <>;
              sensor0_iovdd_vol = <>;
              sensor0_avdd-supply = <>;
              sensor0_avdd_vol = <>;
              sensor0_dvdd-supply = <>;
              sensor0_dvdd_vol = <>;
              sensor0_power_en = <>;
              sensor0_reset = <&pio PK 10 GPIO_ACTIVE_LOW>;
              sensor0_pwdn = <>;
              status = "okay";
      };

      sensor1:sensor@5812010 {
              device_type = "sensor1";
              sensor1_mname = "nvp6158";
              sensor1_twi_cci_id = <5>;
              sensor1_twi_addr = <0x64>;
              sensor1_mclk_id = <2>;
              sensor1_pos = "front";
              sensor1_isp_used = <0>;
              sensor1_fmt = <0>;
              sensor1_stby_mode = <0>;
              sensor1_vflip = <0>;
              sensor1_hflip = <0>;
              sensor1_iovdd-supply = <>;
              sensor1_iovdd_vol = <>;
              sensor1_avdd-supply = <>;
              sensor1_avdd_vol = <>;
              sensor1_dvdd-supply = <>;
              sensor1_dvdd_vol = <>;
              sensor1_power_en = <>;
              sensor1_reset = <&pio PG 13 GPIO_ACTIVE_LOW>;
              sensor1_pwdn = <>;
              status = "okay";
      };

      sensor_list0:sensor_list@200b820 {
              sensor00_mname = "gc5035_mipi";
              sensor00_twi_addr = <0x6c>;
              sensor00_type = <1>;
              sensor00_hflip =  <0>;
              sensor00_vflip = <0>;
              sensor00_act_used = <1>;
              sensor00_act_name = "dw9714_act";
              sensor00_act_twi_addr = <0x18>;
              sensor01_mname = "ov5675_mipi";
              sensor01_twi_addr = <0x6c>;
              sensor01_type = <1>;
              sensor01_hflip =  <0>;
              sensor01_vflip = <0>;
              sensor01_act_used = <1>;
              sensor01_act_name = "dw9714_act";
              sensor01_act_twi_addr = <0x18>;
              sensor02_mname = "sp5409_mipi";
              sensor02_twi_addr = <0x78>;
              sensor02_type = <1>;
              sensor02_hflip =  <0>;
              sensor02_vflip = <0>;
              sensor02_act_used = <1>;
              sensor02_act_name = "dw9714_act";
              sensor02_act_twi_addr = <0x18>;
              status  = "disabled";
      };

      sensor_list1:sensor_list@200b830 {
              sensor10_mname = "gc02m2_mipi";
              sensor10_twi_addr = <0x20>;
              sensor10_type = <1>;
              sensor10_hflip =  <0>;
              sensor10_vflip = <0>;
              sensor10_act_used = <0>;
              sensor10_act_name = "";
              sensor10_act_twi_addr = <>;
              sensor11_mname = "ov02a10_mipi";
              sensor11_twi_addr = <0x7a>;
              sensor11_type = <1>;
              sensor11_hflip =  <1>;
              sensor11_vflip = <0>;
              sensor11_act_used = <0>;
              sensor11_act_name = "";
              sensor11_act_twi_addr = <>;
              sensor12_mname = "gc030a_mipi";
              sensor12_twi_addr = <0x42>;
              sensor12_type = <1>;
              sensor12_hflip =  <0>;
              sensor12_vflip = <0>;
              sensor12_act_used = <0>;
              sensor12_act_name = "";
              sensor12_act_twi_addr = <>;
              status  = "disabled";
