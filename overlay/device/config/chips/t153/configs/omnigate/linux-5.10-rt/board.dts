	dmic_pins_a: dmic@0 {
		/* DMIC_PIN: CLK, DATA0, DATA1, DATA2 */
		pins = "PF2", "PF3", "PF4", "PF5";
		function = "dmic";
		drive-strength = <10>;
		bias-disable;
	};

	dmic_pins_b: dmic@1 {
		pins = "PF2", "PF3", "PF4", "PF5";
		function = "io_disabled";
		drive-strength = <10>;
		bias-disable;
	};

	ledc_pins_default: ledc@0 {
		pins = "PJ8";
		function = "ledc";
		drive-strength = <20>;
	};

	ledc_pins_sleep: ledc@1 {
		pins = "PJ8";
		function = "gpio_in";
	};

	gmac0_pins_default: gmac0@0 {
		pins = "PJ0", "PJ1", "PJ2", "PJ3", "PJ4", "PJ5", "PJ6", "PJ7",
			"PJ8", "PJ9", "PJ10", "PJ11", "PJ12", "PJ13", "PJ14", "PJ15";
		function = "rgmii0";
		drive-strength = <40>;
		bias-pull-up;
	};

	gmac0_pins_sleep: gmac0@1 {
		pins = "PJ0", "PJ1", "PJ2", "PJ3", "PJ4", "PJ5", "PJ6", "PJ7",
			"PJ8", "PJ9", "PJ10", "PJ11", "PJ12", "PJ13", "PJ14", "PJ15";
		function = "io_disabled";
		bias-disable;
	};

	gmac1_pins_default: gmac1@0 {
		pins = "PG0", "PG1", "PG2", "PG3", "PG4", "PG5", "PG6", "PG7",
			"PG8", "PG9", "PG10", "PG11", "PG12", "PG13", "PG14", "PG15";
		function = "rgmii1";
		drive-strength = <40>;
		bias-pull-up;
	};

	gmac1_pins_sleep: gmac1@1 {
		pins = "PG0", "PG1", "PG2", "PG3", "PG4", "PG5", "PG6", "PG7",
			"PG8", "PG9", "PG10", "PG11", "PG12", "PG13", "PG14", "PG15";
		function = "io_disabled";
		bias-disable;
	};

	rtp_pins_default: rtp@0 {
		pins = "PA0", "PA1", "PA2", "PA3";
		function = "tp";
	};

	rtp_pins_sleep: rtp@1 {
		pins = "PA0", "PA1", "PA2", "PA3";
