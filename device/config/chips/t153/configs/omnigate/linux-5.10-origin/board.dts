                max-speed = <1000>;  /* Max speed capability */
                reset-gpios = <&pio PJ 3 GPIO_ACTIVE_LOW>;
                /* PHY datasheet rst time */
                reset-assert-us = <10000>;
                reset-deassert-us = <100000>;
        };
};

