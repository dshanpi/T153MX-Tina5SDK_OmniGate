&gmac0_phy0 {
        compatible = "ethernet-phy-id001c.c916";
        reg = <0x1>;         /* 如果你的 PHY 硬件地址是 1，这里保持 0x1 */
        max-speed = <1000>;  /* Max speed capability */
        reset-gpios = <&pio PJ 2 GPIO_ACTIVE_LOW>;
        reset-assert-us = <10000>;
        reset-deassert-us = <30000>;
};

&gmac1_phy0 {
        compatible = "ethernet-phy-id001c.c916";
        reg = <0x1>;         /* 如果 GMAC1 的 PHY 地址也是 1，因为在不同的 mdio 总线上，所以没问题 */
        max-speed = <1000>;  
        reset-gpios = <&pio PJ 3 GPIO_ACTIVE_LOW>;
        reset-assert-us = <10000>;
        reset-deassert-us = <100000>;
};

/* 2. GMAC 节点的配置保持你的不变 */
&gmac0 {
        phy-mode = "rgmii";
        pinctrl-names = "default", "sleep";
        pinctrl-0 = <&gmac0_pins_default>;
        pinctrl-1 = <&gmac0_pins_sleep>;
        phy-handle = <&gmac0_phy0>;
        //aw,soc-phy-clk-en;
        // phy-supply = <&reg_dcdc1>;
        tx-delay = <4>;
        rx-delay = <6>;
        status = "okay";
};

&gmac1 {
        phy-mode = "rgmii";
        pinctrl-names = "default", "sleep";
        pinctrl-0 = <&gmac1_pins_default>;
        pinctrl-1 = <&gmac1_pins_sleep>;
        phy-handle = <&gmac1_phy0>;
        //aw,soc-phy-clk-en;
        tx-delay = <0>;
        rx-delay = <0>;
        // dwmac-supply = <&reg_dcdc1>;
        // phy-supply = <&reg_dcdc1>;
        status = "okay";
};

&dma {
	reset-control;
};

&dma1 {
       status="disabled";
};

&rtp {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&rtp_pins_default>;
	pinctrl-1 = <&rtp_pins_sleep>;
	allwinner,tp-sensitive-adjust = <0xa>;
	allwinner,filter-type = <0x3>;
	status = "disabled";
};


