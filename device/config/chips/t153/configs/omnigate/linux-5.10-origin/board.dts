/dts-v1/;

#include "sun8iw22p1.dtsi"
#include <dt-bindings/input/input.h>

/{
	board = "t153", "t153-demo";
	compatible = "allwinner,t153", "arm,sun8iw22p1";
	aliases {
	};

	reg_usb0_vbus: usb0-vbus {
		compatible = "regulator-fixed";
		regulator-name = "usb0-vbus";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		regulator-enable-ramp-delay = <1000>;
		enable-active-high;
	};

	reg_usb1_vbus: usb1-vbus {
		compatible = "regulator-fixed";
		regulator-name = "usb1-vbus";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		regulator-enable-ramp-delay = <1000>;
		enable-active-high;
	};

	reg_vdd_cpu: reg_vdd_cpu {
		compatible = "sunxi-pwm-regulator";
		pwms = <&pwmcs0 4 5000 1>;
		regulator-name = "vdd_cpu";
		regulator-min-microvolt = <810000>;
		regulator-max-microvolt = <1150000>;
		regulator-settling-time-us = <4000>;
		regulator-always-on;
		regulator-boot-on;
		status = "okay";
	};

	reserved-memory {
		rv_sram_reserved: riscvsram0@40000 {
			reg = <0x0 0x00040000 0x0 0x0002BFFF>;
			no-map;
			sleep-data-loss;
		};

		e907_mem_fw: e907_mem_fw@44000000 {
			/* boot0 & uboot0 load elf addr */
			reg = <0x0 0x44000000 0x0 0x00200000>;
		};

		/*
			* The name should be "vdev%dbuffer".
			* Its size should be not less than
			*     RPMSG_BUF_SIZE * (num of buffers in a vring) * 2
			*   = 512 * (num of buffers in a vring) * 2
			*/
		rv_vdev0buffer: vdev0buffer@42100000 {
			compatible = "shared-dma-pool";
			reg = <0x0 0x42100000 0x0 0x40000>;
			no-map;
		};

		/*
			* The name should be "vdev%dvring%d".
			* The size of each should be not less than
			*     PAGE_ALIGN(vring_size(num, align))
			*   = PAGE_ALIGN(16 * num + 6 + 2 * num + (pads for align) + 6 + 8 * num)
			*
			* (Please refer to the vring layout in include/uapi/linux/virtio_ring.h)
			*/
		rv_vdev0vring0: vdev0vring0@42140000 {
			reg = <0x0 0x42140000 0x0 0x2000>;
			no-map;
		};
		rv_vdev0vring1: vdev0vring1@42142000 {
			reg = <0x0 0x42142000 0x0 0x2000>;
			no-map;
		};

		e907_rpbuf_reserved: e907_rpbuf@42144000 {
			compatible = "shared-dma-pool";
			no-map;
			reg = <0x0 0x42144000 0x0 0x80000>;
		};

		e907_share_irq_table: share_irq_table@421c4000 {
			reg = <0x0 0x421c4000 0x0 0x1000>;
			no-map;
		};

		e907_dram_reserved: e907_dram@421c5000 {
			reg = <0x0 0x421c5000 0x0 0x00300000>;
			no-map;
		};
	};

	rpbuf_controller0: rpbuf_controller@0 {
			compatible = "allwinner,rpbuf-controller";
			remoteproc = <&e907_rproc>;
			ctrl_id = <0>;
			memory-region = <&e907_rpbuf_reserved>;
			status = "okay";
	};

	can0 {
		compatible = "allwinner,sun8i-t153-can";
		reg = <0x0 0x0453C800 0x0 0x400>,
			<0x0 0x04538000 0x0 0x4400>,
			<0x0 0x04530000 0x0 0x1000>,
			<0x0 0x04534000 0x0 0x1000>;
		reg-names = "can", "message_ram", "can_top", "can_dma";
		interrupts = <GIC_SPI 36 IRQ_TYPE_LEVEL_HIGH>, <GIC_SPI 35 IRQ_TYPE_LEVEL_HIGH>, <GIC_SPI 37 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "int0", "int_top", "int1";
		clocks = <&ccu CLK_CAN0>, <&ccu CLK_BUS_CAN0>, <&ccu CLK_MBUS_CAN_GATE>;
		clock-names = "can_clk", "can_bus", "can_mbus";
		resets = <&ccu RST_BUS_CAN0>, <&ccu RST_BUS_CAN_SYS>;
		reset-names = "can_rst", "can_sys_rst";
		clock-frequency = <40000000>;
		allwinner,ram-cfg = <0x0 0 0 64 64 64 32 32>;
		pinctrl-0 = <&can0_pins_active>;
		pinctrl-1 = <&can0_pins_sleep>;
		pinctrl-names = "default", "sleep";
		status = "okay";
	};

	can1 {
		compatible = "allwinner,sun8i-t153-can";
		reg = <0x0 0x04541800 0x0 0x400>,
				<0x0 0x0453D000 0x0 0x4400>,
				<0x0 0x04531000 0x0 0x1000>,
				<0x0 0x04535000 0x0 0x1000>;
		reg-names = "can", "message_ram", "can_top", "can_dma";
		interrupts = <GIC_SPI 144 IRQ_TYPE_LEVEL_HIGH>, <GIC_SPI 146 IRQ_TYPE_LEVEL_HIGH>, <GIC_SPI 145 IRQ_TYPE_LEVEL_HIGH>;
		interrupt-names = "int0", "int_top", "int1";
		clocks = <&ccu CLK_CAN1>, <&ccu CLK_BUS_CAN1>, <&ccu CLK_MBUS_CAN_GATE>;
		clock-names = "can_clk", "can_bus", "can_mbus";
		resets = <&ccu RST_BUS_CAN1>, <&ccu RST_BUS_CAN_SYS>;
		reset-names = "can_rst", "can_sys_rst";
		clock-frequency = <40000000>;
		allwinner,ram-cfg = <0x0 0 0 64 64 64 32 32>;
		pinctrl-0 = <&can1_pins_active>;
		pinctrl-1 = <&can1_pins_sleep>;
		pinctrl-names = "default", "sleep";
		status = "okay";
	};

};

&pio {
           sdc3_pins_a: sdc3@0 {
                                pins = "PE0", "PE5";
                                function = "sdc3";
                                drive-strength = <40>;
                                bias-pull-up;
                        };

                        sdc3_pins_c: sdc3@2 {
                                pins = "PE6", "PE7", "PE8", "PE9";
                                function = "sdc3";
                                drive-strength = <30>;
                                bias-pull-up;
                        };
	uart0_pins_active: uart0_pins@0 {
		pins = "PB9", "PB10";
		function = "uart0";
	};

	uart0_pins_sleep: uart0_pins@1 {
		pins = "PB9", "PB10";
		function = "io_disabled";
	};

	uart1_pins_active: uart1_pins@0 {
		pins = "PG6", "PG7", "PG8", "PG9";
		function = "uart1";
		drive-strength = <10>;
		bias-pull-up;
	};

	uart1_pins_sleep: uart1_pins@1 {
		pins = "PG6", "PG7", "PG8", "PG9";
		function = "gpio_in";
	};

	uart2_pins_active: uart2_pins@0 {
		pins = "PD2", "PD3", "PD1", "PD0";
		function = "uart2";
	};

	uart2_pins_sleep: uart2_pins@1 {
		pins = "PD2", "PD3", "PD1", "PD0";
		function = "io_disabled";
	};

	uart3_pins_active: uart3_pins@0 {
		pins = "PD14", "PD15", "PD16", "PD17";
		function = "uart3";
	};

	uart3_pins_sleep: uart3_pins@1 {
		pins = "PD14", "PD15", "PD16", "PD17";
		function = "io_disabled";
	};

	uart4_pins_active: uart4_pins@0 {
		pins = "PD6", "PD7", "PD5", "PD4";
		function = "uart4";
	};

	uart4_pins_sleep: uart4_pins@1 {
		pins = "PD6", "PD7", "PD5", "PD4";
		function = "io_disabled";
	};

	uart5_pins_active: uart5_pins@0 {
		pins = "PC9", "PC10", "PC11", "PC8";
		function = "uart5";
	};

	uart5_pins_sleep: uart5_pins@1 {
		pins = "PC9", "PC10", "PC11", "PC8";
		function = "io_disabled";
	};

	uart6_pins_active: uart6_pins@0 {
		pins = "PA14", "PA15", "PE5", "PE6";
		function = "uart6";
	};

	uart6_pins_sleep: uart6_pins@1 {
		pins = "PA14", "PA15", "PE5", "PE6";
		function = "io_disabled";
	};

	uart7_pins_active: uart7_pins@0 {
		pins = "PB13", "PB14", "PB11", "PB12";
		function = "uart7";
                drive-strength = <10>;
                bias-pull-up;

	};

	uart7_pins_sleep: uart7_pins@1 {
		pins = "PB13", "PB14", "PB11", "PB12";
		function = "io_disabled";
	};

	uart8_pins_active: uart8_pins@0 {
		pins = "PD10", "PD11", "PD12", "PD13";
		function = "uart8";
	};

	uart8_pins_sleep: uart8_pins@1 {
		pins = "PD10", "PD11", "PD12", "PD13";
		function = "io_disabled";
	};

	uart9_pins_active: uart9_pins@0 {
		pins = "PD0", "PD1", "PD2", "PD3";
		function = "uart9";
	};

	uart9_pins_sleep: uart9_pins@1 {
		pins = "PD0", "PD1", "PD2", "PD3";
		function = "io_disabled";
	};

	can0_pins_active: can0_pins@0{
		pins = "PJ12", "PJ14";
		function = "can0";
		drive-strength = <20>;
	};

	can0_pins_sleep: can0_pins@1{
		pins = "PJ12", "PJ14";
		function = "io_disabled";
		bias-disable;
	};

	can1_pins_active: can1_pins@0{
		pins = "PJ14", "PJ15";
		function = "can1";
		drive-strength = <20>;
	};

	can1_pins_sleep: can1_pins@1{
		pins = "PJ14", "PJ15";
		function = "io_disabled";
		bias-disable;
	};

	spi0_pins_default: spi0@0 {
		pins = "PC2", "PC3"; /* mosi, miso */
		function = "spi0";
		drive-strength = <20>;
	};

	spi0_pins_cs: spi0@1 {
		pins = "PC1", "PC4", "PC5"; /* cs, wp, hold */
		function = "spi0";
		drive-strength = <20>;
		bias-pull-up;
	};

	spi0_pins_clk: spi0@2 {
		pins = "PC0"; /* clk */
		function = "spi0";
		drive-strength = <40>;
	};

	spi0_pins_sleep: spi0@3 {
		pins = "PC0", "PC1", "PC2", "PC3", "PC4", "PC5";
		function = "gpio_in";
		drive-strength = <10>;
	};
	twi2_pins_default: twi2@0 {
		pins = "PB2", "PB3";
		function = "twi2";
		drive-strength = <10>;
		bias-pull-up;
	};

	twi2_pins_sleep: twi2@1 {
		pins = "PB2", "PB3";
		function = "gpio_in";
	};

	twi4_pins_default: twi4@0 {
		pins = "PB13", "PB14";
		function = "twi4";
		drive-strength = <10>;
		bias-pull-up;
	};

	twi4_pins_sleep: twi4@1 {
		pins = "PB13", "PB14";
		function = "gpio_in";
	};

	pwmcs0_0_pins_active: pwmcs0_0@0 {
		pins = "PB8";
		function = "pwm0_0";
		drive-strength = <20>;
	};

	pwmcs0_0_pins_sleep: pwmcs0_0@1 {
		pins = "PB8";
		function = "gpio_in";
		bias-pull-down;
	};

	pwmcs0_4_pins_active: pwmcs0_4@0 {
		pins = "PB13";
		function = "pwm0_4";
		drive-strength = <20>;
	};

	pwmcs0_4_pins_sleep: pwmcs0_4@1 {
		pins = "PB13";
		function = "gpio_in";
		bias-pull-down;
	};

	gpadc0_pins_default: gpadc0@0 {
		pins = "PA4", "PA5", "PA6", "PA7", "PA8", "PA9", "PA10", "PA11", "PA12", "PA13";
		function = "gpadc0";
	};

	gpadc0_pins_sleep: gpadc0@1 {
		pins = "PA4", "PA5", "PA6", "PA7", "PA8", "PA9", "PA10", "PA11", "PA12", "PA13";
		function = "gpio_in";
	};

	gpadc1_pins_default: gpadc1@0 {
		pins = "PA14","PA15";
		function = "gpadc1";
	};

	gpadc1_pins_sleep: gpadc1@1 {
		pins = "PA14", "PA15";
		function = "gpio_in";
	};

	irrx0_pins_default: irrx0@0 {
		pins = "PJ12";
		function = "ir0";
	};

	irrx0_pins_sleep: irrx0@1 {
		pins = "PJ12";
		function = "gpio_in";
	};

	irrx1_pins_default: irrx1@0 {
		pins = "PJ13";
		function = "ir1";
	};

	irrx1_pins_sleep: irrx1@1 {
		pins = "PJ13";
		function = "gpio_in";
	};

	irrx2_pins_default: irrx2@0 {
		pins = "PJ14";
		function = "ir2";
	};

	irrx2_pins_sleep: irrx2@1 {
		pins = "PJ14";
		function = "gpio_in";
	};

	irrx3_pins_default: irrx3@0 {
		pins = "PJ15";
		function = "ir3";
	};

	irrx3_pins_sleep: irrx3@1 {
		pins = "PJ15";
		function = "gpio_in";
	};

	irtx0_pins_default: irtx@0 {
		pins = "PJ9";
		function = "ir";
	};

	irtx0_pins_sleep: irtx@1 {
		pins = "PJ9";
		function = "gpio_in";
	};

	dmic_pins_a: dmic@0 {
		/* DMIC_PIN: CLK, DATA0, DATA1, DATA2 */
		pins = "PF2", "PF3", "PF4", "PF5";
		function = "dmic";
		drive-strength = <10>;
		bias-disable;
	};

	dmic_pins_b: dmic@1 {
		pins = "PF2", "PF3", "PF4", "PF5";
		function = "io_disabled";
		drive-strength = <10>;
		bias-disable;
	};

	ledc_pins_default: ledc@0 {
		pins = "PJ8";
		function = "ledc";
		drive-strength = <20>;
	};

	ledc_pins_sleep: ledc@1 {
		pins = "PJ8";
		function = "gpio_in";
	};

        gmac0_pins_default: gmac0@0 {
                pins = "PA4","PA5","PA6","PA7","PA8","PA9","PA10","PA11","PA12","PA13",
				"PA14","PA15","PA16","PA17","PA18","PA19";
                function = "rgmii0";
                drive-strength = <40>;
                bias-pull-up;
        };

        gmac0_pins_sleep: gmac0@1 {
                pins = "PA4","PA5","PA6","PA7","PA8","PA9","PA10","PA11","PA12","PA13",
				"PA14","PA15","PA16","PA17","PA18","PA19";
                function = "io_disabled";
                bias-disable;
        };
	gmac1_pins_default: gmac1@0 {
		pins = "PG0", "PG1", "PG2", "PG3", "PG4", "PG5", "PG6", "PG7",
			"PG8", "PG9", "PG10", "PG11", "PG12", "PG13", "PG14", "PG15";
		function = "rgmii1";
		drive-strength = <40>;
		bias-pull-up;
	};

	gmac1_pins_sleep: gmac1@1 {
		pins = "PG0", "PG1", "PG2", "PG3", "PG4", "PG5", "PG6", "PG7",
			"PG8", "PG9", "PG10", "PG11", "PG12", "PG13", "PG14", "PG15";
		function = "io_disabled";
		bias-disable;
	};

	rtp_pins_default: rtp@0 {
		pins = "PA0", "PA1", "PA2", "PA3";
		function = "tp";
	};

	rtp_pins_sleep: rtp@1 {
		pins = "PA0", "PA1", "PA2", "PA3";
		function = "gpio_in";
	};

	spi2_pins_default: spi2@0 {
		pins = "PE2", "PE3", "PE4";
		function = "spi2";
		drive-strength = <10>;
	};

	spi2_pins_cs: spi2@1 {
		pins = "PE7";
		function = "spi2";
		drive-strength = <10>;
		bias-pull-up;
	};

	spi2_pins_sleep: spi2@2 {
		pins = "PE2", "PE3", "PE4", "PE7";
		function = "io_disabled";
		bias-disable;
	};

};
&uart0 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart0_pins_active>;
	pinctrl-1 = <&uart0_pins_sleep>;
	status = "okay";
};

&uart1 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart1_pins_active>;
	pinctrl-1 = <&uart1_pins_sleep>;
	status = "disabled";
};

&uart2 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart2_pins_active>;
	pinctrl-1 = <&uart2_pins_sleep>;
	status = "disabled";
};

&uart3 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart3_pins_active>;
	pinctrl-1 = <&uart3_pins_sleep>;
	status = "disabled";
};

&uart4 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart4_pins_active>;
	pinctrl-1 = <&uart4_pins_sleep>;
	status = "disabled";
};

&uart5 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart5_pins_active>;
	pinctrl-1 = <&uart5_pins_sleep>;
	status = "disabled";
};

&uart6 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart6_pins_active>;
	pinctrl-1 = <&uart6_pins_sleep>;
	status = "disabled";
};

&uart7 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart7_pins_active>;
	pinctrl-1 = <&uart7_pins_sleep>;
	uart-has-rtscts;
	status = "okay";
};

&uart8 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart8_pins_active>;
	pinctrl-1 = <&uart8_pins_sleep>;
	status = "disabled";
};

&uart9 {
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&uart9_pins_active>;
	pinctrl-1 = <&uart9_pins_sleep>;
	status = "disabled";
};

&soc {
	e907_rproc: e907_rproc@1a00000 {
		mboxes = <&msgbox 0>, <&msgbox 2>;
		mbox-names = "arm-kick", "arm-standby";
		memory-region = <&rv_vdev0buffer>, <&rv_vdev0vring0>, <&rv_vdev0vring1>, <&e907_dram_reserved>;
		fw-region = <&e907_mem_fw>;
		fw-partitions = "riscv0", "riscv0-r";
		fw-partition-sectors = <2048>;
		memory-mappings =
			/* < DA      len        PA >	*/
			/* SRAM A2 */
			< 0x40000    0x2BFFF    0x40000 >,
			/* SHARED SRAM */
			< 0x1000000  0x7ffff    0x1000000 >,
			/* DRAM SPACE1 */
			< 0x40000000 0x3f000000 0x40000000>,
			/* DRAM SPACE2 */
			< 0x80000000 0x3f000000 0x80000000>,
			/* DRAM SPACE3 */
			< 0xC0000000 0x3f000000 0xC0000000>;
		standby-ctrl-en = <0x1>;
		standby-record-reg = <0x07090114>;
		share-irq = "e907";
		//auto-boot;
		status = "okay";
		rproc_wdt: rproc_wdt@0 {
			timeout_ms = <6000>;
			try_times = <3>;
			reset_type = <0x2>;
			status="okay";
		};
	};

	gpio-keys {
		compatible = "gpio-keys";
		status = "okay";

		power {
			label = "Power Button";
			linux,code = <KEY_POWER>;
			debounce-interval = <20>;
			//gpios = <&rtc_pio PW 1 GPIO_ACTIVE_HIGH>;
		};

		volume-up {
			label = "Volume Up";
			linux,code = <KEY_VOLUMEUP>;
			debounce-interval = <20>;
			//gpios = <&rtc_pio PW 2 GPIO_ACTIVE_HIGH>;
		};

		volume-down {
			label = "Volume Down";
			linux,code = <KEY_VOLUMEDOWN>;
			debounce-interval = <20>;
			//gpios = <&rtc_pio PW 3 GPIO_ACTIVE_HIGH>;
		};
	};

	auto_print@54321 {
		reg = <0x0 0x54321 0x0 0x0>;
		device_type = "auto_print";
		status = "okay";
	};

	mailbox_test: mailbox_test@0 {
		compatible = "core0-mailbox-test";
		mboxes = <&msgbox_core0 7>;
		mbox-names = "tx|rx0";
		status = "okay";
	};
};

&spi0 {
	pinctrl-0 = <&spi0_pins_default &spi0_pins_cs &spi0_pins_clk>;
	pinctrl-1 = <&spi0_pins_sleep>;
	pinctrl-names = "default", "sleep";
	sunxi,spi-bus-mode = <SUNXI_SPI_BUS_NAND>;
	sunxi,spi-cs-mode = <SUNXI_SPI_CS_SOFT>;
	status = "disabled";

	spi-nand@0 {
			compatible = "spi-nand";
			spi-max-frequency=<100000000>;
			reg = <0x0>;
			spi-rx-bus-width=<0x04>;
			spi-tx-bus-width=<0x04>;
			status="disabled";
	};
};

&sdc2 {
	non-removable;
	bus-width = <8>;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	no-sdio;
	no-sd;
	ctl-spec-caps = <0x328>;
	cap-mmc-highspeed;
	sunxi-power-save-mode;
	sunxi-dis-signal-vol-sw;
	mmc-bootpart-noacc;
	/*cap-hsq;*/
	cqe-on;
	ctl-cmdq-md = <0x2>;
	/* b2c-ecc-on; */
	/* cqe-ecc-on; */
	max-frequency = <150000000>;
	/*vmmc-supply = <&reg_cldo3>;*/
	/*emmc io vol 3.3v*/
	/*vqmmc-supply = <&reg_aldo1>;*/
	/*emmc io vol 1.8v*/
	/*vqmmc-supply = <&reg_cldo1>;*/
	status = "okay";
};

&sdc0 {
	bus-width = <4>;
	cd-gpios = <&pio PF 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	/*non-removable;*/
	/*broken-cd;*/
	/*cd-inverted*/
	/*data3-detect;*/
	/*card-pwr-gpios = <&pio PH 14 1 1 2 0xffffffff>;*/
	cd-used-24M;
	cd-set-debounce = <0x1>;
	cap-sd-highspeed;
	sd-uhs-sdr50;
	sd-uhs-ddr50;
	sd-uhs-sdr104;
	no-sdio;
	no-mmc;
	/* b2c-ecc-on; */
	sunxi-power-save-mode;
	/*sunxi-dis-signal-vol-sw;*/
	sunxi-signal-vol-sw-without-pmu;
	max-frequency = <150000000>;
	ctl-spec-caps = <0x428>;
	/*vmmc-supply = <&reg_cldo3>;*/
	/*vqmmc33sw-supply = <&reg_cldo3>;*/
	/*vdmmc33sw-supply = <&reg_cldo3>;*/
	/*vqmmc18sw-supply = <&reg_aldo4>;*/
	/*vdmmc18sw-supply = <&reg_aldo4>;*/
	status = "okay";
};
&sdc3 {
        bus-width = <4>;
        no-mmc;
        no-sd;
        cap-sd-highspeed;
        /*sd-uhs-sdr12
        sd-uhs-sdr25;
        sd-uhs-sdr50;
        sd-uhs-ddr50;
        sd-uhs-sdr104;*/
        /*sunxi-power-save-mode;*/
        sunxi-dis-signal-vol-sw;
        cap-sdio-irq;
        keep-power-in-suspend;
        ignore-pm-notify;
        max-frequency = <50000000>;
        ctl-spec-caps = <0x428>;
        status = "okay";
};
